# Single account (legacy format — still supported):
# OPENPROVIDER_USERNAME=your-username
# OPENPROVIDER_PASSWORD=your-password

# Multiple accounts — use OPENPROVIDER_{NAME}_USERNAME / _PASSWORD:
OPENPROVIDER_MYCOMPANY_USERNAME=your-username
OPENPROVIDER_MYCOMPANY_PASSWORD=your-password
# OPENPROVIDER_OTHER_USERNAME=other-username
# OPENPROVIDER_OTHER_PASSWORD=other-password
